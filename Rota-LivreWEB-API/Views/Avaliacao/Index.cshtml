@{
    Layout = null;
}

@model List<Rota_LivreWEB_API.Models.Avaliacao>

@{
    ViewData["Title"] = "Avaliações do Passeio";
    int idPasseio = Model.FirstOrDefault()?.id_passeio ?? 0;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rota Livre - Avaliações</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ===== VARIÁVEIS ===== */
        :root {
            --primary-color: #1a535c;
            --secondary-color: #4ecdc4;
            --accent-color: #ff6b6b;
            --light-color: #fff9f5;
            --dark-color: #1a535c;
            --warning-color: #f39c12;
            --success-color: #2ecc71;
            --gray-bg: #f8f9fa;
        }

        /* ===== RESET ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9f2f5 100%);
            min-height: 100vh;
            color: #333;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            position: relative;
        }

        /* ===== FUNDO DECORATIVO ===== */
        .background-pattern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(78, 205, 196, 0.08) 0%, transparent 20%), radial-gradient(circle at 80% 70%, rgba(255, 107, 107, 0.05) 0%, transparent 25%), radial-gradient(circle at 40% 80%, rgba(26, 83, 92, 0.06) 0%, transparent 30%);
            z-index: -2;
            pointer-events: none;
        }

        .brand-compass {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 150px;
            height: 150px;
            opacity: 0.04;
            z-index: -1;
            background: radial-gradient(circle, var(--secondary-color) 3px, transparent 3px), conic-gradient(from 0deg, var(--primary-color) 0deg 90deg, var(--secondary-color) 90deg 180deg, var(--accent-color) 180deg 270deg, var(--dark-color) 270deg 360deg);
            background-size: 100% 100%;
            border-radius: 50%;
            filter: blur(1px);
            pointer-events: none;
        }

        .route-dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 30%, var(--secondary-color) 2px, transparent 2px), radial-gradient(circle at 40% 70%, var(--primary-color) 2px, transparent 2px), radial-gradient(circle at 60% 20%, var(--accent-color) 2px, transparent 2px), radial-gradient(circle at 80% 50%, var(--dark-color) 2px, transparent 2px);
            background-size: 200px 200px;
            opacity: 0.03;
            z-index: -1;
            pointer-events: none;
        }

        /* ===== HEADER ===== */
        .cabecalho {
            background-color: rgba(255, 255, 255, 0.95);
            box-shadow: 0 4px 20px rgba(78, 205, 196, 0.15);
            position: fixed;
            width: 100%;
            top: 0;
            left: 0;
            z-index: 1050;
            padding: 15px 0;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--secondary-color);
        }

        .name-pj {
            font-weight: 800;
            font-size: 1.8rem;
            margin: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            position: relative;
            margin-left: 20px;
        }

            .name-pj::after {
                content: "✦";
                position: absolute;
                right: -25px;
                top: -5px;
                color: var(--accent-color);
                font-size: 20px;
                -webkit-text-fill-color: initial;
                animation: spin 4s linear infinite;
            }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .cabecalho .text-end {
            z-index: 1100;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            align-items: center;
            margin-right: 20px;
        }

        .opcA {
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            min-width: 120px;
        }

        .opc1 {
            background: linear-gradient(135deg, var(--primary-color), #236c78);
            border: none;
            color: white;
            box-shadow: 0 4px 15px rgba(26, 83, 92, 0.3);
        }

            .opc1:hover {
                background: linear-gradient(135deg, #236c78, var(--primary-color));
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(26, 83, 92, 0.4);
            }

        /* ===== MAIN CONTAINER ===== */
        main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 100px 20px 80px;
        }

        /* ===== TÍTULO DA PÁGINA ===== */
        .page-header {
            text-align: center;
            margin-bottom: 40px;
            animation: fadeInUp 0.8s ease;
        }

            .page-header h1 {
                font-size: 36px;
                font-weight: 800;
                color: var(--primary-color);
                margin-bottom: 15px;
                position: relative;
                display: inline-block;
            }

                .page-header h1 i {
                    color: var(--warning-color);
                    margin-right: 10px;
                }

                .page-header h1::after {
                    content: '';
                    position: absolute;
                    bottom: -10px;
                    left: 50%;
                    transform: translateX(-50%);
                    width: 80px;
                    height: 4px;
                    background: linear-gradient(90deg, var(--primary-color), var(--warning-color));
                    border-radius: 2px;
                }

            .page-header p {
                color: #666;
                font-size: 16px;
                margin-top: 20px;
            }

        /* ===== SEÇÃO DE AVALIAÇÕES ===== */
        .avaliacoes-section {
            margin-bottom: 50px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            padding-bottom: 10px;
            border-bottom: 2px solid #eee;
        }

            .section-title i {
                width: 35px;
                height: 35px;
                background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 16px;
            }

            .section-title h2 {
                font-size: 22px;
                font-weight: 700;
                color: var(--primary-color);
                margin: 0;
            }

        /* Cards de avaliações */
        .avaliacoes-list {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 25px;
        }

        .avaliacao-card {
            background: white;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 25px rgba(26, 83, 92, 0.08);
            transition: all 0.3s ease;
            border: 1px solid rgba(0,0,0,0.05);
        }

            .avaliacao-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 15px 35px rgba(26, 83, 92, 0.15);
            }

        .avaliacao-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            flex-wrap: wrap;
            gap: 10px;
        }

            .avaliacao-header strong {
                font-size: 16px;
                font-weight: 700;
                color: var(--primary-color);
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .avaliacao-header strong i {
                    color: var(--secondary-color);
                    font-size: 14px;
                }

        .avaliacao-data {
            font-size: 12px;
            color: #999;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .avaliacao-data i {
                font-size: 11px;
            }

        .avaliacao-estrelas {
            margin-bottom: 12px;
        }

            .avaliacao-estrelas span {
                font-size: 18px;
                letter-spacing: 2px;
            }

        .star-filled {
            color: var(--warning-color);
        }

        .star-empty {
            color: #ddd;
        }

        .avaliacao-feedback {
            font-size: 14px;
            color: #555;
            line-height: 1.6;
            background: var(--gray-bg);
            padding: 15px;
            border-radius: 15px;
            margin-top: 10px;
        }

        /* Estado vazio */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background: white;
            border-radius: 30px;
            box-shadow: 0 15px 35px rgba(26, 83, 92, 0.1);
        }

            .empty-state i {
                font-size: 80px;
                color: var(--warning-color);
                margin-bottom: 20px;
                opacity: 0.5;
            }

            .empty-state h3 {
                font-size: 24px;
                color: var(--primary-color);
                margin-bottom: 10px;
            }

            .empty-state p {
                color: #666;
            }

        /* ===== FORMULÁRIO DE AVALIAÇÃO ===== */
        .form-section {
            background: white;
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 15px 35px rgba(26, 83, 92, 0.1);
            animation: fadeInUp 0.8s ease;
        }

        .form-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #eee;
        }

            .form-header i {
                width: 40px;
                height: 40px;
                background: linear-gradient(135deg, var(--success-color), #27ae60);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 18px;
            }

            .form-header h3 {
                font-size: 22px;
                font-weight: 700;
                color: var(--primary-color);
                margin: 0;
            }

        /* Estrelas de avaliação */
        .star-rating-input {
            display: flex;
            flex-direction: row-reverse;
            justify-content: flex-end;
            gap: 5px;
        }

            .star-rating-input input {
                display: none;
            }

            .star-rating-input label {
                font-size: 30px;
                color: #ddd;
                cursor: pointer;
                transition: all 0.2s ease;
            }

                .star-rating-input label:hover,
                .star-rating-input label:hover ~ label,
                .star-rating-input input:checked ~ label {
                    color: var(--warning-color);
                }

        .form-group {
            margin-bottom: 20px;
        }

            .form-group label {
                font-weight: 600;
                color: var(--primary-color);
                margin-bottom: 8px;
                display: block;
            }

        textarea.form-control {
            border-radius: 15px;
            border: 2px solid #e0e0e0;
            padding: 15px;
            font-size: 14px;
            transition: all 0.3s ease;
            resize: vertical;
        }

            textarea.form-control:focus {
                outline: none;
                border-color: var(--secondary-color);
                box-shadow: 0 0 0 3px rgba(78, 205, 196, 0.2);
            }

        .btn-enviar {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

            .btn-enviar:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(78, 205, 196, 0.4);
            }

        .btn-voltar {
            background: transparent;
            border: 2px solid #e0e0e0;
            color: #666;
            padding: 12px 30px;
            border-radius: 40px;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

            .btn-voltar:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                transform: translateY(-3px);
            }

        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        /* ===== FOOTER ===== */
        footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 12px 20px;
            box-shadow: 0 -5px 25px rgba(78, 205, 196, 0.15);
            display: flex;
            justify-content: space-around;
            z-index: 1000;
            border-top: 3px solid var(--secondary-color);
        }

            footer button {
                background: none;
                border: none;
                font-size: 15px;
                font-weight: 600;
                color: var(--primary-color);
                cursor: pointer;
                padding: 10px 25px;
                border-radius: 40px;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                gap: 8px;
                opacity: 0.7;
            }

                footer button i {
                    font-size: 18px;
                }

                footer button:hover {
                    color: var(--secondary-color);
                    background: rgba(78, 205, 196, 0.1);
                    transform: translateY(-3px);
                    opacity: 1;
                }

        /* ===== ANIMAÇÕES ===== */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== RESPONSIVIDADE ===== */
        @@media (max-width: 768px) {
            main {
                padding: 90px 15px 80px;
            }

            .page-header h1 {
                font-size: 28px;
            }

            .avaliacoes-list {
                grid-template-columns: 1fr;
            }

            .form-section {
                padding: 20px;
            }

            .brand-compass {
                width: 80px;
                height: 80px;
                bottom: 20px;
                right: 20px;
            }

            footer button {
                padding: 8px 15px;
                font-size: 13px;
            }
        }

        @@media (max-width: 576px) {
            .page-header h1 {
                font-size: 24px;
            }

            .avaliacao-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .form-actions {
                flex-direction: column;
            }

            .btn-enviar, .btn-voltar {
                justify-content: center;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <!-- Elementos decorativos -->
    <div class="background-pattern"></div>
    <div class="brand-compass"></div>
    <div class="route-dots"></div>

    <!-- Header -->
    <header class="cabecalho">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <a href="/" class="d-flex align-items-center text-decoration-none">
                    <h1 class="name-pj">Rota Livre</h1>
                </a>
                <div class="text-end">
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/Login/Login'">Entrar</button>
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/RotaLivre/Create'">Cadastrar</button>
                </div>
            </div>
        </div>
    </header>

    <main>
        <!-- Cabeçalho da página -->
        <div class="page-header">
            <h1>
                <i class="fas fa-star"></i> Avaliações do Passeio
            </h1>
            <p>Veja o que outros viajantes estão falando e compartilhe sua experiência</p>
        </div>

        <!-- Seção de avaliações existentes -->
        <div class="avaliacoes-section">
            <div class="section-title">
                <i class="fas fa-comments"></i>
                <h2>O que os viajantes estão dizendo</h2>
            </div>

            @if (Model.Any())
            {
                <div class="avaliacoes-list">
                    @foreach (var item in Model)
                    {
                        <div class="avaliacao-card">
                            <div class="avaliacao-header">
                                <strong>
                                    <i class="fas fa-user-circle"></i> @item.nome_completo
                                </strong>
                                <span class="avaliacao-data">
                                    <i class="fas fa-calendar-alt"></i>
                                    @item.data_feedback.AddHours(-3).ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </div>
                            <div class="avaliacao-estrelas">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= item.nota)
                                    {
                                        <span class="star-filled">★</span>
                                    }
                                    else
                                    {
                                        <span class="star-empty">★</span>
                                    }
                                }
                            </div>
                            <div class="avaliacao-feedback">
                                <i class="fas fa-quote-left" style="color: var(--secondary-color); margin-right: 5px; opacity: 0.5;"></i>
                                @item.feedback
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-star"></i>
                    <h3>Nenhuma avaliação ainda</h3>
                    <p>Seja o primeiro a avaliar este passeio e ajude outros viajantes!</p>
                </div>
            }
        </div>

        <!-- Formulário de nova avaliação -->
        <div class="form-section">
            <div class="form-header">
                <i class="fas fa-edit"></i>
                <h3>Deixe sua avaliação</h3>
            </div>

            <form asp-action="Comentar" method="post">
                <input type="hidden" name="id_passeio" value="@ViewBag.IdPasseio" />
                <input type="hidden" name="id_usuario" value="@ViewBag.IdUsuario" />
                <input type="hidden" name="nome_completo" value="@ViewBag.NomeUsuario" />

                <div class="form-group">
                    <label>Sua nota</label>
                    <div class="star-rating-input">
                        <input type="radio" id="star-5" name="nota" value="5" required />
                        <label for="star-5">★</label>
                        <input type="radio" id="star-4" name="nota" value="4" required />
                        <label for="star-4">★</label>
                        <input type="radio" id="star-3" name="nota" value="3" required />
                        <label for="star-3">★</label>
                        <input type="radio" id="star-2" name="nota" value="2" required />
                        <label for="star-2">★</label>
                        <input type="radio" id="star-1" name="nota" value="1" required />
                        <label for="star-1">★</label>
                    </div>
                </div>

                <div class="form-group">
                    <label>Seu comentário</label>
                    <textarea name="feedback" class="form-control" rows="4" placeholder="Compartilhe sua experiência com este passeio..." required></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-enviar">
                        <i class="fas fa-paper-plane"></i> Enviar Avaliação
                    </button>
                    <a href="javascript:history.back()" class="btn-voltar">
                        <i class="fas fa-arrow-left"></i> Voltar
                    </a>
                </div>
            </form>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <button id="btnTopo" type="button" onclick="window.location.href='/HomeBase/Home'">
            <i class="fas fa-home"></i> Home
        </button>
        <button onclick="window.location.href='/MeusPasseios/MeusPasseios'">
            <i class="fas fa-bus"></i> Meus Passeios
        </button>
        <button onclick="window.location.href='/Perfil/Perfil'">
            <i class="fas fa-user"></i> Perfil
        </button>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Efeito de scroll no header
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.cabecalho');
            if (header) {
                if (window.scrollY > 50) {
                    header.style.padding = '10px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.98)';
                } else {
                    header.style.padding = '15px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.95)';
                }
            }
        });

        // Scroll suave para o topo
        const btnTopo = document.getElementById('btnTopo');
        if (btnTopo) {
            btnTopo.addEventListener('click', function(e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }
    </script>
</body>
</html>