@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rota Livre - Senha Alterada</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ===== VARIÁVEIS ===== */
        :root {
            --primary-color: #1a535c;
            --secondary-color: #4ecdc4;
            --accent-color: #ff6b6b;
            --light-color: #fff9f5;
            --dark-color: #1a535c;
            --success-color: #2ecc71;
        }

        /* ===== RESET ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9f2f5 100%);
            min-height: 100vh;
            color: #333;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            position: relative;
        }

        /* ===== FUNDO DECORATIVO ===== */
        .background-pattern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(78, 205, 196, 0.08) 0%, transparent 20%), radial-gradient(circle at 80% 70%, rgba(255, 107, 107, 0.05) 0%, transparent 25%), radial-gradient(circle at 40% 80%, rgba(26, 83, 92, 0.06) 0%, transparent 30%);
            z-index: -2;
            pointer-events: none;
        }

        .brand-compass {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 150px;
            height: 150px;
            opacity: 0.04;
            z-index: -1;
            background: radial-gradient(circle, var(--secondary-color) 3px, transparent 3px), conic-gradient(from 0deg, var(--primary-color) 0deg 90deg, var(--secondary-color) 90deg 180deg, var(--accent-color) 180deg 270deg, var(--dark-color) 270deg 360deg);
            background-size: 100% 100%;
            border-radius: 50%;
            filter: blur(1px);
            pointer-events: none;
        }

        .route-dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 30%, var(--secondary-color) 2px, transparent 2px), radial-gradient(circle at 40% 70%, var(--primary-color) 2px, transparent 2px), radial-gradient(circle at 60% 20%, var(--accent-color) 2px, transparent 2px), radial-gradient(circle at 80% 50%, var(--dark-color) 2px, transparent 2px);
            background-size: 200px 200px;
            opacity: 0.03;
            z-index: -1;
            pointer-events: none;
        }

        /* ===== HEADER ===== */
        .cabecalho {
            background-color: rgba(255, 255, 255, 0.95);
            box-shadow: 0 4px 20px rgba(78, 205, 196, 0.15);
            position: fixed;
            width: 100%;
            top: 0;
            left: 0;
            z-index: 1050;
            padding: 15px 0;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--secondary-color);
        }

        .name-pj {
            font-weight: 800;
            font-size: 1.8rem;
            margin: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            position: relative;
            margin-left: 20px;
        }

            .name-pj::after {
                content: "✦";
                position: absolute;
                right: -25px;
                top: -5px;
                color: var(--accent-color);
                font-size: 20px;
                -webkit-text-fill-color: initial;
                animation: spin 4s linear infinite;
            }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .cabecalho .text-end {
            z-index: 1100;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            align-items: center;
            margin-right: 20px;
        }

        .opcA {
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            min-width: 120px;
        }

        .opc1 {
            background: linear-gradient(135deg, var(--primary-color), #236c78);
            border: none;
            color: white;
            box-shadow: 0 4px 15px rgba(26, 83, 92, 0.3);
        }

            .opc1:hover {
                background: linear-gradient(135deg, #236c78, var(--primary-color));
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(26, 83, 92, 0.4);
            }

        /* ===== MAIN CONTAINER ===== */
        .success-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 100px 20px 60px;
        }

        .success-card {
            max-width: 500px;
            width: 100%;
            background: white;
            border-radius: 30px;
            box-shadow: 0 25px 50px rgba(26, 83, 92, 0.15);
            overflow: hidden;
            animation: fadeInUp 0.8s ease;
            position: relative;
            text-align: center;
        }

            .success-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 5px;
                background: linear-gradient(90deg, var(--success-color), var(--secondary-color), var(--success-color));
            }

        .success-header {
            padding: 50px 40px 30px;
            text-align: center;
            background: linear-gradient(135deg, rgba(46, 204, 113, 0.05), rgba(78, 205, 196, 0.05));
        }

        .success-icon {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--success-color), #27ae60);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            box-shadow: 0 10px 30px rgba(46, 204, 113, 0.3);
            animation: pulse 2s infinite;
        }

            .success-icon i {
                font-size: 50px;
                color: white;
            }

        @@keyframes pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.7);
                transform: scale(1);
            }

            50% {
                box-shadow: 0 0 0 15px rgba(46, 204, 113, 0);
                transform: scale(1.05);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(46, 204, 113, 0);
                transform: scale(1);
            }
        }

        .success-header h1 {
            font-size: 32px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--success-color), #27ae60);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .success-header p {
            color: #666;
            font-size: 16px;
            max-width: 350px;
            margin: 0 auto;
        }

        .success-body {
            padding: 30px 40px 50px;
        }

        /* ===== MENSAGEM ===== */
        .message-box {
            background: linear-gradient(135deg, rgba(46, 204, 113, 0.08), rgba(78, 205, 196, 0.05));
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 30px;
            border: 1px solid rgba(46, 204, 113, 0.2);
        }

            .message-box i {
                font-size: 60px;
                color: var(--success-color);
                margin-bottom: 15px;
            }

            .message-box h3 {
                font-size: 24px;
                font-weight: 700;
                color: var(--success-color);
                margin-bottom: 10px;
            }

            .message-box p {
                color: #666;
                font-size: 15px;
                margin: 0;
            }

        /* ===== BOTÃO ===== */
        .btn-login {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            border-radius: 15px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
        }

            .btn-login::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                transition: left 0.5s ease;
            }

            .btn-login:hover::before {
                left: 100%;
            }

            .btn-login:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(78, 205, 196, 0.4);
                color: white;
            }

            .btn-login i {
                font-size: 18px;
                transition: transform 0.3s ease;
            }

            .btn-login:hover i {
                transform: translateX(5px);
            }

        /* ===== INFORMAÇÕES ADICIONAIS ===== */
        .info-text {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #e0e0e0;
            font-size: 13px;
            color: #999;
        }

            .info-text a {
                color: var(--primary-color);
                text-decoration: none;
            }

                .info-text a:hover {
                    color: var(--secondary-color);
                }

        /* ===== FOOTER ===== */
        .footer {
            background: linear-gradient(135deg, var(--primary-color), var(--dark-color));
            color: white;
            padding: 40px 0 20px;
            margin-top: 60px;
            position: relative;
        }

            .footer h5 {
                margin-bottom: 20px;
                font-weight: 600;
            }

            .footer ul {
                list-style: none;
                padding: 0;
            }

                .footer ul li {
                    margin-bottom: 10px;
                }

                    .footer ul li a {
                        color: rgba(255, 255, 255, 0.8);
                        text-decoration: none;
                        transition: color 0.3s ease;
                    }

                        .footer ul li a:hover {
                            color: white;
                            padding-left: 5px;
                        }

        .social-icons a {
            display: inline-block;
            width: 40px;
            height: 40px;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            text-align: center;
            line-height: 40px;
            margin-right: 10px;
            transition: all 0.3s ease;
            color: white;
        }

            .social-icons a:hover {
                background-color: var(--secondary-color);
                transform: translateY(-3px);
            }

        .copyright {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding-top: 20px;
            margin-top: 40px;
            text-align: center;
            color: rgba(255, 255, 255, 0.7);
        }

        /* ===== ANIMAÇÕES ===== */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes checkmark {
            0% {
                stroke-dashoffset: 100;
            }

            100% {
                stroke-dashoffset: 0;
            }
        }

        /* ===== RESPONSIVIDADE ===== */
        @@media (max-width: 768px) {
            .success-header {
                padding: 40px 25px 25px;
            }

            .success-body {
                padding: 25px 25px 40px;
            }

            .success-header h1 {
                font-size: 28px;
            }

            .success-icon {
                width: 80px;
                height: 80px;
            }

                .success-icon i {
                    font-size: 40px;
                }

            .message-box i {
                font-size: 50px;
            }

            .message-box h3 {
                font-size: 22px;
            }

            .brand-compass {
                width: 80px;
                height: 80px;
                bottom: 20px;
                right: 20px;
            }
        }

        @@media (max-width: 576px) {
            .success-header h1 {
                font-size: 24px;
            }

            .success-header p {
                font-size: 14px;
            }

            .message-box h3 {
                font-size: 20px;
            }

            .btn-login {
                padding: 12px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <!-- Elementos decorativos -->
    <div class="background-pattern"></div>
    <div class="brand-compass"></div>
    <div class="route-dots"></div>

    <!-- Header -->
    <header class="cabecalho">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <a href="/" class="d-flex align-items-center text-decoration-none">
                    <h1 class="name-pj">Rota Livre</h1>
                </a>
                <div class="text-end">
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/Login/Login'">Entrar</button>
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/RotaLivre/Create'">Cadastrar</button>
                </div>
            </div>
        </div>
    </header>

    <!-- Success Container -->
    <div class="success-container">
        <div class="success-card">
            <div class="success-header">
                <div class="success-icon">
                    <i class="fas fa-check"></i>
                </div>
                <h1>Senha Alterada!</h1>
                <p>Sua senha foi atualizada com sucesso</p>
            </div>

            <div class="success-body">
                <div class="message-box">
                    <i class="fas fa-lock"></i>
                    <h3>Tudo pronto!</h3>
                    <p>Agora você pode acessar sua conta com sua nova senha.</p>
                </div>

                <a href="/Login/Login" class="btn-login">
                    <i class="fas fa-sign-in-alt"></i> Fazer login
                </a>

                <div class="info-text">
                    <i class="fas fa-shield-alt"></i> Sua conta está mais segura!
                    <a href="#">Saiba mais</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-4">
                    <h5>Rota Livre</h5>
                    <p>Sua plataforma para descobrir e explorar os melhores destinos turísticos.</p>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="col-md-2 mb-4">
                    <h5>Links</h5>
                    <ul>
                        <li><a href="#">Início</a></li>
                        <li><a href="#">Sobre</a></li>
                        <li><a href="#">Destinos</a></li>
                        <li><a href="#">Contato</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Recursos</h5>
                    <ul>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Guias</a></li>
                        <li><a href="#">Aplicativo</a></li>
                        <li><a href="#">FAQ</a></li>
                    </ul>
                </div>
                <div class="col-md-3 mb-4">
                    <h5>Contato</h5>
                    <ul>
                        <li><i class="fas fa-envelope me-2"></i> contato@rotalivre.com</li>
                        <li><i class="fas fa-phone me-2"></i> (11) 99999-9999</li>
                        <li><i class="fas fa-map-marker-alt me-2"></i> São Paulo, Brasil</li>
                    </ul>
                </div>
            </div>
            <div class="copyright">
                <p>&copy; 2025 Rota Livre. Todos os direitos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Efeito de scroll no header
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.cabecalho');
            if (window.scrollY > 50) {
                header.style.padding = '10px 0';
                header.style.backgroundColor = 'rgba(255, 255, 255, 0.98)';
            } else {
                header.style.padding = '15px 0';
                header.style.backgroundColor = 'rgba(255, 255, 255, 0.95)';
            }
        });

        // Confete animado ao carregar a página (opcional)
        function createConfetti() {
            const colors = ['#1a535c', '#4ecdc4', '#ff6b6b', '#2ecc71'];
            for (let i = 0; i < 50; i++) {
                const confetti = document.createElement('div');
                confetti.style.position = 'fixed';
                confetti.style.width = '10px';
                confetti.style.height = '10px';
                confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.top = '-10px';
                confetti.style.borderRadius = '50%';
                confetti.style.opacity = '0.8';
                confetti.style.pointerEvents = 'none';
                confetti.style.zIndex = '9999';
                confetti.style.animation = `fall ${Math.random() * 2 + 2}s linear forwards`;
                document.body.appendChild(confetti);

                setTimeout(() => {
                    confetti.remove();
                }, 3000);
            }
        }

        // Adicionar animação de queda para os confetes
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes fall {
                to {
                    transform: translateY(100vh) rotate(360deg);
                    opacity: 0;
                }
            }
        `;
        document.head.appendChild(style);

        // Criar confetes ao carregar (opcional - descomente se quiser)
        // createConfetti();
    </script>
</body>
</html>