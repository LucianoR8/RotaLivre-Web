
@model List<Rota_LivreWEB_API.Models.Passeio>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rota Livre - Meus Passeios Pendentes</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ===== VARIÁVEIS ===== */
        :root {
            --primary-color: #1a535c;
            --secondary-color: #4ecdc4;
            --accent-color: #ff6b6b;
            --light-color: #fff9f5;
            --dark-color: #1a535c;
            --warning-color: #f39c12;
            --gray-bg: #f8f9fa;
        }

        /* ===== RESET ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9f2f5 100%);
            min-height: 100vh;
            color: #333;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            position: relative;
        }

        /* ===== FUNDO DECORATIVO ===== */
        .background-pattern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(78, 205, 196, 0.08) 0%, transparent 20%), radial-gradient(circle at 80% 70%, rgba(255, 107, 107, 0.05) 0%, transparent 25%), radial-gradient(circle at 40% 80%, rgba(26, 83, 92, 0.06) 0%, transparent 30%);
            z-index: -2;
            pointer-events: none;
        }

        .brand-compass {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 150px;
            height: 150px;
            opacity: 0.04;
            z-index: -1;
            background: radial-gradient(circle, var(--secondary-color) 3px, transparent 3px), conic-gradient(from 0deg, var(--primary-color) 0deg 90deg, var(--secondary-color) 90deg 180deg, var(--accent-color) 180deg 270deg, var(--dark-color) 270deg 360deg);
            background-size: 100% 100%;
            border-radius: 50%;
            filter: blur(1px);
            pointer-events: none;
        }

        .route-dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 30%, var(--secondary-color) 2px, transparent 2px), radial-gradient(circle at 40% 70%, var(--primary-color) 2px, transparent 2px), radial-gradient(circle at 60% 20%, var(--accent-color) 2px, transparent 2px), radial-gradient(circle at 80% 50%, var(--dark-color) 2px, transparent 2px);
            background-size: 200px 200px;
            opacity: 0.03;
            z-index: -1;
            pointer-events: none;
        }

        /* ===== HEADER ===== */
        .cabecalho {
            background-color: rgba(255, 255, 255, 0.95);
            box-shadow: 0 4px 20px rgba(78, 205, 196, 0.15);
            position: fixed;
            width: 100%;
            top: 0;
            left: 0;
            z-index: 1050;
            padding: 15px 0;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--secondary-color);
        }

        .name-pj {
            font-weight: 800;
            font-size: 1.8rem;
            margin: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            position: relative;
            margin-left: 20px;
        }

        .name-pj::after {
            content: "✦";
            position: absolute;
            right: -25px;
            top: -5px;
            color: var(--accent-color);
            font-size: 20px;
            -webkit-text-fill-color: initial;
            animation: spin 4s linear infinite;
        }

        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .cabecalho .text-end {
            z-index: 1100;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            align-items: center;
            margin-right: 20px;
        }

        .opcA {
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            min-width: 120px;
        }

        .opc1 {
            background: linear-gradient(135deg, var(--primary-color), #236c78);
            border: none;
            color: white;
            box-shadow: 0 4px 15px rgba(26, 83, 92, 0.3);
        }

        .opc1:hover {
            background: linear-gradient(135deg, #236c78, var(--primary-color));
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(26, 83, 92, 0.4);
        }

        /* ===== MAIN CONTAINER ===== */
        main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 100px 20px 80px;
        }

        /* ===== TÍTULO DA PÁGINA ===== */
        .page-header {
            text-align: center;
            margin-bottom: 50px;
            animation: fadeInUp 0.8s ease;
        }

        .page-header h1 {
            font-size: 36px;
            font-weight: 800;
            color: var(--primary-color);
            margin-bottom: 15px;
            position: relative;
            display: inline-block;
        }

        .page-header h1 i {
            color: var(--warning-color);
            margin-right: 10px;
        }

        .page-header h1::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color), var(--warning-color));
            border-radius: 2px;
        }

        .page-header p {
            color: #666;
            font-size: 16px;
            margin-top: 20px;
        }

        /* ===== PRODUTOS CONTAINER ===== */
        .produtos-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 30px;
            animation: fadeInUp 0.8s ease 0.2s both;
        }

        /* ===== CARD DO PASSEIO ===== */
        .produto {
            background: white;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 35px rgba(26, 83, 92, 0.1);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            cursor: pointer;
            position: relative;
        }

        .produto:hover {
            transform: translateY(-12px) scale(1.02);
            box-shadow: 0 25px 45px rgba(26, 83, 92, 0.2);
        }

        /* Container da imagem */
        .imagem-container {
            position: relative;
            overflow: hidden;
            height: 250px;
        }

        .imagem_produto {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s ease;
        }

        .produto:hover .imagem_produto {
            transform: scale(1.15);
        }

        /* Overlay na imagem */
        .imagem-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to bottom, transparent 0%, rgba(26, 83, 92, 0.8) 100%);
            opacity: 0;
            transition: opacity 0.4s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .produto:hover .imagem-overlay {
            opacity: 1;
        }

        .ver-detalhes {
            background: linear-gradient(135deg, var(--warning-color), #e67e22);
            color: white;
            padding: 12px 25px;
            border-radius: 40px;
            font-size: 14px;
            font-weight: 600;
            transform: translateY(20px);
            transition: all 0.4s ease;
            border: 2px solid white;
        }

        .produto:hover .ver-detalhes {
            transform: translateY(0);
        }

        /* Badge de pendente */
        .pendente-badge {
            position: absolute;
            top: 15px;
            right: 15px;
            background: linear-gradient(135deg, var(--warning-color), #e67e22);
            backdrop-filter: blur(5px);
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            color: white;
            display: flex;
            align-items: center;
            gap: 6px;
            z-index: 2;
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }

        .produto:hover .pendente-badge {
            transform: scale(1.05);
        }

        .pendente-badge i {
            font-size: 12px;
        }

        /* Conteúdo do card */
        .museu_conteudo {
            padding: 25px;
            background: white;
            position: relative;
        }

        .nome {
            font-size: 20px;
            font-weight: 700;
            color: var(--primary-color);
            margin: 0 0 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nome i {
            color: var(--warning-color);
            font-size: 18px;
        }

        .linha_nome {
            width: 50px;
            height: 3px;
            background: linear-gradient(90deg, var(--primary-color), var(--warning-color));
            margin: 12px 0;
            transition: width 0.3s ease;
            border-radius: 2px;
        }

        .produto:hover .linha_nome {
            width: 80px;
        }

        /* Informações adicionais */
        .passeio-info {
            display: flex;
            gap: 15px;
            margin-top: 15px;
            flex-wrap: wrap;
        }

        .info-tag {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: #666;
            background: var(--gray-bg);
            padding: 4px 12px;
            border-radius: 20px;
        }

        .info-tag i {
            color: var(--secondary-color);
            font-size: 11px;
        }

        /* ===== ESTADO VAZIO ===== */
        .empty-state {
            text-align: center;
            padding: 80px 20px;
            background: white;
            border-radius: 30px;
            box-shadow: 0 15px 35px rgba(26, 83, 92, 0.1);
            animation: fadeInUp 0.8s ease;
        }

        .empty-state i {
            font-size: 80px;
            color: var(--warning-color);
            margin-bottom: 20px;
            opacity: 0.5;
        }

        .empty-state h3 {
            font-size: 24px;
            color: var(--primary-color);
            margin-bottom: 10px;
        }

        .empty-state p {
            color: #666;
            margin-bottom: 25px;
        }

        .btn-explorar {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        .btn-explorar:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(78, 205, 196, 0.3);
            color: white;
        }

        /* ===== FOOTER ===== */
        footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 12px 20px;
            box-shadow: 0 -5px 25px rgba(78, 205, 196, 0.15);
            display: flex;
            justify-content: space-around;
            z-index: 1000;
            border-top: 3px solid var(--secondary-color);
        }

        footer button {
            background: none;
            border: none;
            font-size: 15px;
            font-weight: 600;
            color: var(--primary-color);
            cursor: pointer;
            padding: 10px 25px;
            border-radius: 40px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            opacity: 0.7;
        }

        footer button i {
            font-size: 18px;
        }

        footer button:hover {
            color: var(--secondary-color);
            background: rgba(78, 205, 196, 0.1);
            transform: translateY(-3px);
            opacity: 1;
        }

        footer button.active {
            color: var(--secondary-color);
            background: rgba(78, 205, 196, 0.1);
            opacity: 1;
            position: relative;
        }

        footer button.active::after {
            content: '';
            position: absolute;
            bottom: 5px;
            left: 50%;
            transform: translateX(-50%);
            width: 30px;
            height: 3px;
            background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
            border-radius: 2px;
        }

        /* ===== ANIMAÇÕES ===== */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== RESPONSIVIDADE ===== */
        @@media (max-width: 768px) {
            main {
                padding: 90px 15px 80px;
            }

            .page-header h1 {
                font-size: 28px;
            }

            .produtos-container {
                gap: 20px;
            }

            .imagem-container {
                height: 220px;
            }

            .nome {
                font-size: 18px;
            }

            .brand-compass {
                width: 80px;
                height: 80px;
                bottom: 20px;
                right: 20px;
            }

            footer button {
                padding: 8px 15px;
                font-size: 13px;
            }
        }

        @@media (max-width: 576px) {
            .page-header h1 {
                font-size: 24px;
            }

            .page-header p {
                font-size: 14px;
            }

            .produtos-container {
                grid-template-columns: 1fr;
            }

            .imagem-container {
                height: 200px;
            }

            .museu_conteudo {
                padding: 20px;
            }

            .nome {
                font-size: 16px;
            }

            .info-tag {
                font-size: 10px;
                padding: 3px 10px;
            }

            .empty-state h3 {
                font-size: 20px;
            }

            .empty-state i {
                font-size: 60px;
            }
        }
    </style>
</head>
<body>
    <!-- Elementos decorativos -->
    <div class="background-pattern"></div>
    <div class="brand-compass"></div>
    <div class="route-dots"></div>

    <!-- Header -->
    <header class="cabecalho">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <a href="/" class="d-flex align-items-center text-decoration-none">
                    <h1 class="name-pj">Rota Livre</h1>
                </a>
                <div class="text-end">
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/Login/Login'">Entrar</button>
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/RotaLivre/Create'">Cadastrar</button>
                </div>
            </div>
        </div>
    </header>

    <main>
        <!-- Cabeçalho da página -->
        <div class="page-header">
            <h1>
                <i class="fas fa-clock"></i> Minha Lista de Desejos
            </h1>
            <p>Passeios que você quer conhecer. Planeje sua próxima aventura!</p>
        </div>

        @if (!Model.Any())
        {
            <!-- Estado vazio -->
            <div class="empty-state">
                <i class="fas fa-hourglass"></i>
                <h3>Nenhum passeio pendente</h3>
                <p>Você ainda não adicionou nenhum passeio à sua lista. Explore nossos destinos e comece a planejar sua jornada!</p>
                <a href="/HomeBase/Home" class="btn-explorar">
                    <i class="fas fa-compass"></i> Explorar passeios
                </a>
            </div>
        }
        else
        {
            <div class="produtos-container">
                @foreach (var passeio in Model)
                {
                    <div class="produto" 
                         onclick="window.location.href='@Url.Action("Detalhes", "Passeios", new { id = passeio.id_passeio })'">
                        
                        <div class="imagem-container">
                            <img src="@Url.Content("~/img/passeios/" + passeio.img_url)" 
                                 class="imagem_produto" 
                                 alt="@passeio.nome_passeio" />
                            <div class="imagem-overlay">
                                <div class="ver-detalhes">
                                    <i class="fas fa-eye"></i> Ver detalhes
                                </div>
                            </div>
                        </div>

                        <!-- Badge de pendente -->
                        <div class="pendente-badge">
                            <i class="fas fa-hourglass-half"></i>
                            <span>Na lista</span>
                        </div>

                        <div class="museu_conteudo">
                            <p class="nome">
                                <i class="fas fa-map-pin"></i> @passeio.nome_passeio
                            </p>
                            <div class="linha_nome"></div>
                            
                            <div class="passeio-info">
                                <span class="info-tag">
                                    <i class="fas fa-clock"></i> Duração: ~2h
                                </span>
                                <span class="info-tag">
                                    <i class="fas fa-users"></i> Guia incluso
                                </span>
                                @if (passeio.QuantidadeCurtidas > 0)
                                {
                                    <span class="info-tag">
                                        <i class="fas fa-heart"></i> @passeio.QuantidadeCurtidas curtidas
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </main>

    <!-- Footer -->
    <footer>
        <button id="btnTopo" type="button" onclick="window.location.href='/HomeBase/Home'">
            <i class="fas fa-home"></i> Home
        </button>
        <button class="active" onclick="window.location.href='/MeusPasseios/MeusPasseios'">
            <i class="fas fa-bus"></i> Meus Passeios
        </button>
        <button onclick="window.location.href='/Perfil/Perfil'">
            <i class="fas fa-user"></i> Perfil
        </button>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Efeito de scroll no header
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.cabecalho');
            if (header) {
                if (window.scrollY > 50) {
                    header.style.padding = '10px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.98)';
                } else {
                    header.style.padding = '15px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.95)';
                }
            }
        });

        // Scroll suave para o topo
        const btnTopo = document.getElementById('btnTopo');
        if (btnTopo) {
            btnTopo.addEventListener('click', function(e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }

        // Animação de entrada dos cards
        const cards = document.querySelectorAll('.produto');
        if (cards.length > 0) {
            cards.forEach((card, index) => {
                card.style.animation = `fadeInUp 0.6s ease forwards`;
                card.style.animationDelay = `${index * 0.05}s`;
                card.style.opacity = '0';
            });
        }
    </script>
</body>
</html>