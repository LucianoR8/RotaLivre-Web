@model Rota_LivreWEB_API.Models.UsuarioEdicaoViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rota Livre - Editar Perfil</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ===== VARIÁVEIS ===== */
        :root {
            --primary-color: #1a535c;
            --secondary-color: #4ecdc4;
            --accent-color: #ff6b6b;
            --light-color: #fff9f5;
            --dark-color: #1a535c;
            --success-color: #2ecc71;
            --warning-color: #f39c12;
            --gray-bg: #f8f9fa;
        }

        /* ===== RESET ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9f2f5 100%);
            min-height: 100vh;
            color: #333;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            position: relative;
        }

        /* ===== FUNDO DECORATIVO ===== */
        .background-pattern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(78, 205, 196, 0.08) 0%, transparent 20%), radial-gradient(circle at 80% 70%, rgba(255, 107, 107, 0.05) 0%, transparent 25%), radial-gradient(circle at 40% 80%, rgba(26, 83, 92, 0.06) 0%, transparent 30%);
            z-index: -2;
            pointer-events: none;
        }

        .brand-compass {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 150px;
            height: 150px;
            opacity: 0.04;
            z-index: -1;
            background: radial-gradient(circle, var(--secondary-color) 3px, transparent 3px), conic-gradient(from 0deg, var(--primary-color) 0deg 90deg, var(--secondary-color) 90deg 180deg, var(--accent-color) 180deg 270deg, var(--dark-color) 270deg 360deg);
            background-size: 100% 100%;
            border-radius: 50%;
            filter: blur(1px);
            pointer-events: none;
        }

        .route-dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 30%, var(--secondary-color) 2px, transparent 2px), radial-gradient(circle at 40% 70%, var(--primary-color) 2px, transparent 2px), radial-gradient(circle at 60% 20%, var(--accent-color) 2px, transparent 2px), radial-gradient(circle at 80% 50%, var(--dark-color) 2px, transparent 2px);
            background-size: 200px 200px;
            opacity: 0.03;
            z-index: -1;
            pointer-events: none;
        }

        /* ===== HEADER ===== */
        .cabecalho {
            background-color: rgba(255, 255, 255, 0.95);
            box-shadow: 0 4px 20px rgba(78, 205, 196, 0.15);
            position: fixed;
            width: 100%;
            top: 0;
            left: 0;
            z-index: 1050;
            padding: 15px 0;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--secondary-color);
        }

        .name-pj {
            font-weight: 800;
            font-size: 1.8rem;
            margin: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            position: relative;
            margin-left: 20px;
        }

            .name-pj::after {
                content: "✦";
                position: absolute;
                right: -25px;
                top: -5px;
                color: var(--accent-color);
                font-size: 20px;
                -webkit-text-fill-color: initial;
                animation: spin 4s linear infinite;
            }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .cabecalho .text-end {
            z-index: 1100;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            align-items: center;
            margin-right: 20px;
        }

        .opcA {
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            min-width: 120px;
        }

        .opc1 {
            background: linear-gradient(135deg, var(--primary-color), #236c78);
            border: none;
            color: white;
            box-shadow: 0 4px 15px rgba(26, 83, 92, 0.3);
        }

            .opc1:hover {
                background: linear-gradient(135deg, #236c78, var(--primary-color));
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(26, 83, 92, 0.4);
            }

        /* ===== MAIN CONTAINER ===== */
        main {
            max-width: 600px;
            margin: 0 auto;
            padding: 100px 20px 80px;
        }

        /* ===== CARD DO EDITAR PERFIL ===== */
        .edit-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(26, 83, 92, 0.15);
            animation: fadeInUp 0.8s ease;
        }

            .edit-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 5px;
                background: linear-gradient(90deg, var(--primary-color), var(--secondary-color), var(--accent-color));
            }

        /* Cabeçalho do card */
        .edit-header {
            background: linear-gradient(135deg, rgba(26, 83, 92, 0.05), rgba(78, 205, 196, 0.05));
            padding: 40px 40px 20px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        .edit-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            box-shadow: 0 10px 30px rgba(78, 205, 196, 0.3);
        }

            .edit-icon i {
                font-size: 40px;
                color: white;
            }

        .edit-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color);
            margin-bottom: 8px;
        }

        .edit-header p {
            color: #666;
            font-size: 14px;
            max-width: 350px;
            margin: 0 auto;
        }

        /* Corpo do card */
        .edit-body {
            padding: 30px 40px 40px;
        }

        /* ===== FORMULÁRIO ===== */
        .floating-label {
            position: relative;
            margin-bottom: 25px;
        }

            .floating-label i {
                position: absolute;
                left: 18px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--secondary-color);
                font-size: 18px;
                z-index: 2;
            }

            .floating-label input {
                width: 100%;
                padding: 18px 20px 8px 50px;
                border: 2px solid #e0e0e0;
                border-radius: 15px;
                font-size: 15px;
                transition: all 0.3s ease;
                background: white;
            }

                .floating-label input:focus {
                    outline: none;
                    border-color: var(--secondary-color);
                    box-shadow: 0 0 0 3px rgba(78, 205, 196, 0.2);
                }

            .floating-label label {
                position: absolute;
                left: 50px;
                top: 50%;
                transform: translateY(-50%);
                color: #999;
                transition: all 0.3s ease;
                pointer-events: none;
                font-size: 15px;
                z-index: 1;
            }

            .floating-label input:focus ~ label,
            .floating-label input:not(:placeholder-shown) ~ label {
                top: 8px;
                font-size: 11px;
                color: var(--secondary-color);
            }

            /* Placeholder invisível para funcionar o floating label */
            .floating-label input::placeholder {
                opacity: 0;
            }

        /* Campo de data específico */
        input[type="date"] {
            padding-top: 18px;
        }

            input[type="date"] ~ label {
                top: 8px;
                font-size: 11px;
                color: var(--secondary-color);
            }

        /* Validação */
        .text-danger {
            font-size: 12px;
            margin-top: 5px;
            display: block;
            color: var(--accent-color) !important;
        }

        .field-validation-error {
            color: var(--accent-color);
            font-size: 12px;
            margin-top: 5px;
            display: block;
        }

        /* ===== BOTÕES ===== */
        .form-actions {
            display: flex;
            gap: 15px;
            margin-top: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .btn-save {
            flex: 1;
            padding: 14px;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
            border: none;
            border-radius: 15px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

            .btn-save::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
                transition: left 0.5s ease;
            }

            .btn-save:hover::before {
                left: 100%;
            }

            .btn-save:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(78, 205, 196, 0.4);
            }

        .btn-cancel {
            flex: 1;
            padding: 14px;
            background: transparent;
            border: 2px solid #e0e0e0;
            color: #666;
            border-radius: 15px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
        }

            .btn-cancel:hover {
                border-color: var(--accent-color);
                color: var(--accent-color);
                transform: translateY(-3px);
            }

        /* ===== MENSAGENS ===== */
        .alert-custom {
            background: linear-gradient(135deg, rgba(46, 204, 113, 0.1), rgba(78, 205, 196, 0.05));
            border-left: 4px solid var(--success-color);
            border-radius: 12px;
            padding: 15px 20px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            animation: fadeInUp 0.5s ease;
        }

            .alert-custom i {
                font-size: 20px;
                color: var(--success-color);
            }

            .alert-custom span {
                color: #27ae60;
                font-size: 14px;
            }

        .alert-error {
            background: linear-gradient(135deg, rgba(255, 107, 107, 0.1), rgba(255, 107, 107, 0.05));
            border-left: 4px solid var(--accent-color);
        }

            .alert-error i {
                color: var(--accent-color);
            }

            .alert-error span {
                color: #c0392b;
            }

        /* ===== FOOTER ===== */
        footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 12px 20px;
            box-shadow: 0 -5px 25px rgba(78, 205, 196, 0.15);
            display: flex;
            justify-content: space-around;
            z-index: 1000;
            border-top: 3px solid var(--secondary-color);
        }

            footer button {
                background: none;
                border: none;
                font-size: 15px;
                font-weight: 600;
                color: var(--primary-color);
                cursor: pointer;
                padding: 10px 25px;
                border-radius: 40px;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                gap: 8px;
                opacity: 0.7;
            }

                footer button i {
                    font-size: 18px;
                }

                footer button:hover {
                    color: var(--secondary-color);
                    background: rgba(78, 205, 196, 0.1);
                    transform: translateY(-3px);
                    opacity: 1;
                }

        /* ===== ANIMAÇÕES ===== */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== RESPONSIVIDADE ===== */
        @@media (max-width: 768px) {
            main {
                padding: 90px 15px 80px;
            }

            .edit-header {
                padding: 30px 25px 20px;
            }

            .edit-body {
                padding: 25px 25px 35px;
            }

            .edit-header h1 {
                font-size: 24px;
            }

            .edit-icon {
                width: 60px;
                height: 60px;
            }

                .edit-icon i {
                    font-size: 30px;
                }

            .floating-label input {
                padding: 14px 20px 12px 45px;
                font-size: 14px;
            }

            .floating-label label {
                left: 45px;
                font-size: 14px;
            }

            .form-actions {
                flex-direction: column;
            }

            .brand-compass {
                width: 80px;
                height: 80px;
                bottom: 20px;
                right: 20px;
            }

            footer button {
                padding: 8px 15px;
                font-size: 13px;
            }
        }

        @@media (max-width: 576px) {
            .edit-card {
                border-radius: 20px;
            }

            .edit-header h1 {
                font-size: 22px;
            }

            .edit-header p {
                font-size: 13px;
            }

            .btn-save, .btn-cancel {
                padding: 12px;
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <!-- Elementos decorativos -->
    <div class="background-pattern"></div>
    <div class="brand-compass"></div>
    <div class="route-dots"></div>

    <!-- Header -->
    <header class="cabecalho">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <a href="/" class="d-flex align-items-center text-decoration-none">
                    <h1 class="name-pj">Rota Livre</h1>
                </a>
                <div class="text-end">
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/Login/Login'">Entrar</button>
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/RotaLivre/Create'">Cadastrar</button>
                </div>
            </div>
        </div>
    </header>

    <main>
        <div class="edit-card">
            <div class="edit-header">
                <div class="edit-icon">
                    <i class="fas fa-user-edit"></i>
                </div>
                <h1>Editar Perfil</h1>
                <p>Atualize suas informações pessoais</p>
            </div>

            <div class="edit-body">
                <form asp-action="Editar" method="post" id="formEditar">
                    @Html.AntiForgeryToken()

                    <!-- ID do usuário oculto -->
                    <input type="hidden" asp-for="id_usuario" />

                    <!-- Mensagem de sucesso (se houver) -->
                    @if (TempData["Sucesso"] != null)
                    {
                        <div class="alert-custom">
                            <i class="fas fa-check-circle"></i>
                            <span>@TempData["Sucesso"]</span>
                        </div>
                    }

                    <!-- Mensagem de erro (se houver) -->
                    @if (ViewBag.Erro != null)
                    {
                        <div class="alert-custom alert-error">
                            <i class="fas fa-exclamation-triangle"></i>
                            <span>@ViewBag.Erro</span>
                        </div>
                    }

                    <!-- Nome Completo -->
                    <div class="floating-label">
                        <i class="fas fa-user"></i>
                        <input asp-for="nome_completo" type="text" placeholder=" " required />
                        <label asp-for="nome_completo">Nome completo</label>
                        <span asp-validation-for="nome_completo" class="text-danger"></span>
                    </div>

                    <!-- Email -->
                    <div class="floating-label">
                        <i class="fas fa-envelope"></i>
                        <input asp-for="email" type="email" placeholder=" " required />
                        <label asp-for="email">E-mail</label>
                        <span asp-validation-for="email" class="text-danger"></span>
                    </div>

                    <!-- Data de Nascimento -->
                    <div class="floating-label">
                        <i class="fas fa-calendar-alt"></i>
                        <input asp-for="data_nasc" type="date" placeholder=" " required />
                        <label asp-for="data_nasc">Data de nascimento</label>
                        <span asp-validation-for="data_nasc" class="text-danger"></span>
                    </div>

                    <!-- Botões -->
                    <div class="form-actions">
                        <button type="submit" class="btn-save">
                            <i class="fas fa-save"></i> Salvar alterações
                        </button>
                        <a href="/Perfil/Perfil" class="btn-cancel">
                            <i class="fas fa-times"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <button id="btnTopo" type="button" onclick="window.location.href='/HomeBase/Home'">
            <i class="fas fa-home"></i> Home
        </button>
        <button onclick="window.location.href='/MeusPasseios/MeusPasseios'">
            <i class="fas fa-bus"></i> Meus Passeios
        </button>
        <button onclick="window.location.href='/Perfil/Perfil'">
            <i class="fas fa-user"></i> Perfil
        </button>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

    <script>
        // Efeito de scroll no header
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.cabecalho');
            if (header) {
                if (window.scrollY > 50) {
                    header.style.padding = '10px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.98)';
                } else {
                    header.style.padding = '15px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.95)';
                }
            }
        });

        // Scroll suave para o topo
        const btnTopo = document.getElementById('btnTopo');
        if (btnTopo) {
            btnTopo.addEventListener('click', function(e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }

        // Inicializar placeholders para floating labels
        document.querySelectorAll('.floating-label input').forEach(input => {
            input.setAttribute('placeholder', ' ');
        });

        // Para campo de data, já mantém o label no topo
        const dateInput = document.querySelector('input[type="date"]');
        if (dateInput && dateInput.value) {
            dateInput.setAttribute('placeholder', ' ');
        }
    </script>
</body>
</html>