@model Rota_LivreWEB_API.Models.Usuario

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rota Livre - Meu Perfil</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <style>
        /* ===== VARIÁVEIS ===== */
        :root {
            --primary-color: #1a535c;
            --secondary-color: #4ecdc4;
            --accent-color: #ff6b6b;
            --light-color: #fff9f5;
            --dark-color: #1a535c;
            --success-color: #2ecc71;
            --warning-color: #f39c12;
            --danger-color: #e74c3c;
            --gray-bg: #f8f9fa;
        }

        /* ===== RESET ===== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e9f2f5 100%);
            min-height: 100vh;
            color: #333;
            line-height: 1.6;
            margin: 0;
            padding: 0;
            position: relative;
        }

        /* ===== FUNDO DECORATIVO ===== */
        .background-pattern {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, rgba(78, 205, 196, 0.08) 0%, transparent 20%), radial-gradient(circle at 80% 70%, rgba(255, 107, 107, 0.05) 0%, transparent 25%), radial-gradient(circle at 40% 80%, rgba(26, 83, 92, 0.06) 0%, transparent 30%);
            z-index: -2;
            pointer-events: none;
        }

        .brand-compass {
            position: fixed;
            bottom: 40px;
            right: 40px;
            width: 150px;
            height: 150px;
            opacity: 0.04;
            z-index: -1;
            background: radial-gradient(circle, var(--secondary-color) 3px, transparent 3px), conic-gradient(from 0deg, var(--primary-color) 0deg 90deg, var(--secondary-color) 90deg 180deg, var(--accent-color) 180deg 270deg, var(--dark-color) 270deg 360deg);
            background-size: 100% 100%;
            border-radius: 50%;
            filter: blur(1px);
            pointer-events: none;
        }

        .route-dots {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(circle at 20% 30%, var(--secondary-color) 2px, transparent 2px), radial-gradient(circle at 40% 70%, var(--primary-color) 2px, transparent 2px), radial-gradient(circle at 60% 20%, var(--accent-color) 2px, transparent 2px), radial-gradient(circle at 80% 50%, var(--dark-color) 2px, transparent 2px);
            background-size: 200px 200px;
            opacity: 0.03;
            z-index: -1;
            pointer-events: none;
        }

        /* ===== HEADER ===== */
        .cabecalho {
            background-color: rgba(255, 255, 255, 0.95);
            box-shadow: 0 4px 20px rgba(78, 205, 196, 0.15);
            position: fixed;
            width: 100%;
            top: 0;
            left: 0;
            z-index: 1050;
            padding: 15px 0;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--secondary-color);
        }

        .name-pj {
            font-weight: 800;
            font-size: 1.8rem;
            margin: 0;
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            position: relative;
            margin-left: 20px;
        }

            .name-pj::after {
                content: "✦";
                position: absolute;
                right: -25px;
                top: -5px;
                color: var(--accent-color);
                font-size: 20px;
                -webkit-text-fill-color: initial;
                animation: spin 4s linear infinite;
            }

        @@keyframes spin {
            from {
                transform: rotate(0deg);
            }

            to {
                transform: rotate(360deg);
            }
        }

        .cabecalho .text-end {
            z-index: 1100;
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            align-items: center;
            margin-right: 20px;
        }

        .opcA {
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 600;
            transition: all 0.3s ease;
            min-width: 120px;
        }

        .opc1 {
            background: linear-gradient(135deg, var(--primary-color), #236c78);
            border: none;
            color: white;
            box-shadow: 0 4px 15px rgba(26, 83, 92, 0.3);
        }

            .opc1:hover {
                background: linear-gradient(135deg, #236c78, var(--primary-color));
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(26, 83, 92, 0.4);
            }

        /* ===== MAIN CONTAINER ===== */
        main {
            max-width: 1200px;
            margin: 0 auto;
            padding: 100px 20px 80px;
        }

        /* ===== CARD DO PERFIL ===== */
        .profile-card {
            background: white;
            border-radius: 30px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(26, 83, 92, 0.15);
            animation: fadeInUp 0.8s ease;
        }

        /* Cabeçalho do perfil */
        .profile-header {
            background: linear-gradient(135deg, rgba(26, 83, 92, 0.05), rgba(78, 205, 196, 0.05));
            padding: 40px;
            text-align: center;
            border-bottom: 1px solid #eee;
        }

        .profile-avatar {
            position: relative;
            display: inline-block;
            margin-bottom: 20px;
        }

            .profile-avatar img {
                width: 120px;
                height: 120px;
                border-radius: 50%;
                border: 4px solid var(--secondary-color);
                padding: 3px;
                background: white;
                transition: transform 0.3s ease;
            }

                .profile-avatar img:hover {
                    transform: scale(1.05);
                }

            .profile-avatar i {
                position: absolute;
                bottom: 5px;
                right: 5px;
                background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
                border-radius: 50%;
                padding: 8px;
                font-size: 14px;
                color: white;
                border: 2px solid white;
            }

        .profile-header h1 {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-color);
            margin-bottom: 5px;
        }

        .profile-header .member-since {
            color: #666;
            font-size: 14px;
        }

        /* Informações do perfil */
        .profile-info {
            padding: 30px 40px;
        }

        .info-section {
            margin-bottom: 30px;
        }

        .section-title {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #eee;
        }

            .section-title i {
                width: 35px;
                height: 35px;
                background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: white;
                font-size: 16px;
            }

            .section-title h2 {
                font-size: 20px;
                font-weight: 700;
                color: var(--primary-color);
                margin: 0;
            }

        /* Grid de informações */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .info-item {
            background: var(--gray-bg);
            border-radius: 15px;
            padding: 15px 20px;
            transition: all 0.3s ease;
        }

            .info-item:hover {
                transform: translateY(-3px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            }

        .info-label {
            font-size: 12px;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .info-value {
            font-size: 16px;
            font-weight: 600;
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .info-value i {
                color: var(--secondary-color);
                font-size: 14px;
            }

        /* Botões de ação */
        .profile-actions {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #eee;
        }

        .btn-action {
            padding: 12px 28px;
            border-radius: 40px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            border: none;
            text-decoration: none;
        }

        .btn-edit {
            background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
            color: white;
        }

            .btn-edit:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(78, 205, 196, 0.4);
                color: white;
            }

        .btn-logout {
            background: transparent;
            border: 2px solid var(--warning-color);
            color: var(--warning-color);
        }

            .btn-logout:hover {
                background: var(--warning-color);
                color: white;
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(243, 156, 18, 0.3);
            }

        .btn-delete {
            background: transparent;
            border: 2px solid var(--danger-color);
            color: var(--danger-color);
        }

            .btn-delete:hover {
                background: var(--danger-color);
                color: white;
                transform: translateY(-3px);
                box-shadow: 0 10px 25px rgba(231, 76, 60, 0.3);
            }

        /* ===== FOOTER ===== */
        footer {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            padding: 12px 20px;
            box-shadow: 0 -5px 25px rgba(78, 205, 196, 0.15);
            display: flex;
            justify-content: space-around;
            z-index: 1000;
            border-top: 3px solid var(--secondary-color);
        }

            footer button {
                background: none;
                border: none;
                font-size: 15px;
                font-weight: 600;
                color: var(--primary-color);
                cursor: pointer;
                padding: 10px 25px;
                border-radius: 40px;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                gap: 8px;
                opacity: 0.7;
            }

                footer button i {
                    font-size: 18px;
                }

                footer button:hover {
                    color: var(--secondary-color);
                    background: rgba(78, 205, 196, 0.1);
                    transform: translateY(-3px);
                    opacity: 1;
                }

                footer button.active {
                    color: var(--secondary-color);
                    background: rgba(78, 205, 196, 0.1);
                    opacity: 1;
                    position: relative;
                }

                    footer button.active::after {
                        content: '';
                        position: absolute;
                        bottom: 5px;
                        left: 50%;
                        transform: translateX(-50%);
                        width: 30px;
                        height: 3px;
                        background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
                        border-radius: 2px;
                    }

        /* ===== MODAL DE CONFIRMAÇÃO ===== */
        .modal-custom {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

            .modal-custom.show {
                display: flex;
                animation: fadeIn 0.3s ease;
            }

        .modal-content-custom {
            background: white;
            border-radius: 20px;
            max-width: 400px;
            width: 90%;
            padding: 30px;
            text-align: center;
            animation: scaleIn 0.3s ease;
        }

            .modal-content-custom i {
                font-size: 60px;
                color: var(--danger-color);
                margin-bottom: 20px;
            }

            .modal-content-custom h3 {
                font-size: 22px;
                margin-bottom: 10px;
            }

            .modal-content-custom p {
                color: #666;
                margin-bottom: 25px;
            }

        .modal-buttons {
            display: flex;
            gap: 15px;
            justify-content: center;
        }

            .modal-buttons button {
                padding: 10px 25px;
                border-radius: 30px;
                font-weight: 600;
                cursor: pointer;
            }

        .btn-cancel {
            background: #e0e0e0;
            border: none;
            color: #666;
        }

        .btn-confirm-delete {
            background: var(--danger-color);
            border: none;
            color: white;
        }

        @@keyframes scaleIn {
            from {
                transform: scale(0.9);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }

        /* ===== ANIMAÇÕES ===== */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        /* ===== RESPONSIVIDADE ===== */
        @@media (max-width: 768px) {
            main {
                padding: 90px 15px 80px;
            }

            .profile-header {
                padding: 30px;
            }

            .profile-info {
                padding: 25px;
            }

            .profile-header h1 {
                font-size: 24px;
            }

            .profile-avatar img {
                width: 100px;
                height: 100px;
            }

            .info-grid {
                grid-template-columns: 1fr;
            }

            .profile-actions {
                flex-direction: column;
            }

            .btn-action {
                justify-content: center;
            }

            .brand-compass {
                width: 80px;
                height: 80px;
                bottom: 20px;
                right: 20px;
            }

            footer button {
                padding: 8px 15px;
                font-size: 13px;
            }
        }

        @@media (max-width: 576px) {
            .profile-header h1 {
                font-size: 20px;
            }

            .section-title h2 {
                font-size: 18px;
            }

            .info-value {
                font-size: 14px;
            }
        }
    </style>
</head>
<body>
    <!-- Elementos decorativos -->
    <div class="background-pattern"></div>
    <div class="brand-compass"></div>
    <div class="route-dots"></div>

    <!-- Header -->
    <header class="cabecalho">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between">
                <a href="/" class="d-flex align-items-center text-decoration-none">
                    <h1 class="name-pj">Rota Livre</h1>
                </a>
                <div class="text-end">
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/Login/Login'">Entrar</button>
                    <button class="opc1 opcA btn btn-primary" type="button" onclick="window.location.href='/RotaLivre/Create'">Cadastrar</button>
                </div>
            </div>
        </div>
    </header>

    <main>
        <div class="profile-card">
            <!-- Cabeçalho do perfil -->
            <div class="profile-header">
                <div class="profile-avatar">
                    <img src="~/img/profilepic.png" alt="Foto do Perfil">
                    <i class="fas fa-camera"></i>
                </div>
                <h1>@Model.nome_completo</h1>
                <p class="member-since">
                    <i class="fas fa-calendar-alt"></i> Membro desde @DateTime.Now.ToString("MMMM yyyy")
                </p>
            </div>

            <!-- Informações do perfil -->
            <div class="profile-info">
                <div class="info-section">
                    <div class="section-title">
                        <i class="fas fa-user-circle"></i>
                        <h2>Dados Pessoais</h2>
                    </div>
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="info-label">Nome completo</div>
                            <div class="info-value">
                                <i class="fas fa-user"></i>
                                @Model.nome_completo
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">E-mail</div>
                            <div class="info-value">
                                <i class="fas fa-envelope"></i>
                                @Model.email
                            </div>
                        </div>
                        <div class="info-item">
                            <div class="info-label">Data de nascimento</div>
                            <div class="info-value">
                                <i class="fas fa-cake-candles"></i>
                                @Model.data_nasc.ToString("dd/MM/yyyy")
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Botões de ação -->
                <div class="profile-actions">
                    <button class="btn-action btn-edit" type="button" onclick="window.location.href='/Perfil/Editar'">
                        <i class="fas fa-edit"></i> Editar Perfil
                    </button>

                    <form asp-action="Logout" asp-controller="Login" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-action btn-logout">
                            <i class="fas fa-sign-out-alt"></i> Sair da Conta
                        </button>
                    </form>

                    <button type="button" class="btn-action btn-delete" id="btnDeletar">
                        <i class="fas fa-trash-alt"></i> Deletar Conta
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <button id="btnTopo" type="button" onclick="window.location.href='/HomeBase/Home'">
            <i class="fas fa-home"></i> Home
        </button>
        <button onclick="window.location.href='/MeusPasseios/MeusPasseios'">
            <i class="fas fa-bus"></i> Meus Passeios
        </button>
        <button class="active">
            <i class="fas fa-user"></i> Perfil
        </button>
    </footer>

    <!-- Modal de confirmação para deletar conta -->
    <div id="deleteModal" class="modal-custom">
        <div class="modal-content-custom">
            <i class="fas fa-exclamation-triangle"></i>
            <h3>Tem certeza?</h3>
            <p>Esta ação não pode ser desfeita. Todos os seus dados serão permanentemente removidos.</p>
            <div class="modal-buttons">
                <button class="btn-cancel" id="btnCancelDelete">Cancelar</button>
                <form asp-action="Deletar" method="post" style="display:inline;" id="formDelete">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-confirm-delete">Sim, deletar</button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Efeito de scroll no header
        window.addEventListener('scroll', function() {
            const header = document.querySelector('.cabecalho');
            if (header) {
                if (window.scrollY > 50) {
                    header.style.padding = '10px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.98)';
                } else {
                    header.style.padding = '15px 0';
                    header.style.backgroundColor = 'rgba(255, 255, 255, 0.95)';
                }
            }
        });

        // Scroll suave para o topo
        const btnTopo = document.getElementById('btnTopo');
        if (btnTopo) {
            btnTopo.addEventListener('click', function(e) {
                e.preventDefault();
                window.scrollTo({ top: 0, behavior: 'smooth' });
            });
        }

        // Modal de confirmação para deletar conta
        const btnDeletar = document.getElementById('btnDeletar');
        const deleteModal = document.getElementById('deleteModal');
        const btnCancelDelete = document.getElementById('btnCancelDelete');

        if (btnDeletar) {
            btnDeletar.addEventListener('click', function() {
                deleteModal.classList.add('show');
            });
        }

        if (btnCancelDelete) {
            btnCancelDelete.addEventListener('click', function() {
                deleteModal.classList.remove('show');
            });
        }

        // Fechar modal ao clicar fora
        deleteModal.addEventListener('click', function(e) {
            if (e.target === deleteModal) {
                deleteModal.classList.remove('show');
            }
        });
    </script>
</body>
</html>