<Shell
    x:Class="RotaLivreMobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:RotaLivreMobile.Views">

    <TabBar>
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="HomePage" />
        <ShellContent
            Title="Grupo"
            ContentTemplate="{DataTemplate views:GrupoPage}"
            Route="GrupoPage" />
        <ShellContent
            Title="Perfil"
            ContentTemplate="{DataTemplate views:PerfilPage}"
            Route="PerfilPage" />
    </TabBar>

</Shell>
