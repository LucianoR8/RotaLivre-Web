<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RotaLivreMobile.Views.BuscaPage"
    Title="Resultados">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F7FA" Offset="0.0" />
            <GradientStop Color="#FFE9F2F5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid Padding="10">

        <CollectionView
            ItemsSource="{Binding Passeios}"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label
                        Text="Nenhum passeio encontrado"
                        HorizontalOptions="Center"
                        FontSize="20"
                        TextColor="Gray"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Frame
                        Margin="0,5"
                        Padding="0"
                        CornerRadius="15"
                        HasShadow="True">

                        <Grid>

                            <VerticalStackLayout Spacing="5">

                                <Image
                                    Source="{Binding ImagemSource}"
                                    HeightRequest="180"
                                    Aspect="AspectFill"
                                    InputTransparent="True"/>

                                <Label
                                    Text="{Binding Nome}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    Margin="10,5,10,0"
                                    InputTransparent="True"/>

                                <Label
                                    Text="{Binding Descricao}"
                                    Margin="10,0,10,10"
                                    InputTransparent="True"/>

                            </VerticalStackLayout>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnPasseioTapped"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>

                        </Grid>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>