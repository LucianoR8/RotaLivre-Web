<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotaLivreMobile.Views.EditarPerfilPage"
             Title="Editar">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F7FA" Offset="0.0" />
            <GradientStop Color="#FFE9F2F5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Editar Perfil"
                   FontSize="24"
                   HorizontalOptions="Center" />

            <Entry Placeholder="Nome"
                   Text="{Binding Nome}" />

            <Entry Placeholder="Email"
                   Text="{Binding Email}" />

            <DatePicker Date="{Binding DataNasc}" />

            <Frame Padding="0"
                   CornerRadius="60"
                   HeightRequest="120"
                   WidthRequest="120"
                   IsClippedToBounds="True"
                   HorizontalOptions="Center">

                <Image Source="{Binding FotoExibicao}"
               Aspect="AspectFill">

                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSelecionarFotoTapped"/>
                        </Image.GestureRecognizers>

                    </Image>

                </Frame>

                <Button Text="Alterar Foto"
                        Clicked="OnSelecionarFotoTapped"/>

                <Button Text="Remover Foto"
                        BackgroundColor="Red"
                        TextColor="White"
                        Clicked="OnRemoverFotoClicked"/>

            <Button Text="Salvar"
                    BackgroundColor="Green"
                    TextColor="White"
                    Command="{Binding SalvarCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>