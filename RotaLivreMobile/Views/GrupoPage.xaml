<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RotaLivreMobile.Views.GrupoPage"
    Title="Grupo">

    <VerticalStackLayout Padding="20">

        <Label 
        Text="{Binding NomePasseio}" 
        FontSize="22"
        FontAttributes="Bold"
        HorizontalOptions="Center" />

        <Label 
        Text="Você não possui grupo ativo. Escolha um passeio para começar."
        IsVisible="{Binding TemGrupoAtivo, Converter={StaticResource InverseBoolConverter}}" />

        <VerticalStackLayout IsVisible="{Binding TemGrupoAtivo}">

            <Label Text="Código do Grupo:" />
            <Label Text="{Binding CodigoGrupo}" FontSize="20" />

            <Label Text="Participantes:" />

            <CollectionView ItemsSource="{Binding Usuarios}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Label Text="{Binding}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <Button 
        Text="Criar Grupo"
        Command="{Binding CriarGrupoCommand}" />

    </VerticalStackLayout>

</ContentPage>