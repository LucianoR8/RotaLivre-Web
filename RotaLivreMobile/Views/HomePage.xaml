<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RotaLivreMobile.Views.HomePage"
    Title="Home">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F7FA" Offset="0.0" />
            <GradientStop Color="#FFE9F2F5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>


    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15"
            >
            

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="10">

                <Label
                    Grid.Column="0"
                    Text="{Binding NomeUsuario, StringFormat='Olá, {0}'}"
                    FontSize="18"
                    FontAttributes="Bold"
                    VerticalOptions="Center" />

                <SearchBar
                    Grid.Column="1"
                    x:Name="searchBar"
                    Placeholder="Buscar"
                    WidthRequest="140"
                    HeightRequest="45"
                    VerticalOptions="Center"
                    BackgroundColor="#F5F5F5"
                    SearchButtonPressed="OnBuscarPressed" />

            </Grid>

            <CarouselView
                x:Name="carouselCategorias"
                ItemsSource="{Binding Categorias}"
                HeightRequest="200"
                IndicatorView="indicatorCategorias">

                <CarouselView.ItemTemplate>
                    <DataTemplate>

                        <Frame
                            CornerRadius="20"
                            Margin="5"
                            Padding="0"
                            HasShadow="True">

                            <Grid>

                                <Image
                                    Source="{Binding ImgSource}"
                                    Aspect="AspectFill" />

                                <BoxView BackgroundColor="#60000000" />

                                <Label
                                    Text="{Binding TipoCategoria}"
                                    TextColor="White"
                                    FontSize="22"
                                    FontAttributes="Bold"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Tapped="OnCategoriaClicada"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                            </Grid>

                        </Frame>

                    </DataTemplate>
                </CarouselView.ItemTemplate>

            </CarouselView>

            <IndicatorView
                x:Name="indicatorCategorias"
                HorizontalOptions="Center"
                IndicatorColor="LightGray"
                SelectedIndicatorColor="Black" />

            <Label
                Text="Destaques"
                FontSize="22"
                FontAttributes="Bold"
                Margin="0,10,0,5" />

            <VerticalStackLayout
                BindableLayout.ItemsSource="{Binding Destaques}"
                Spacing="10">

                <BindableLayout.ItemTemplate>
                    <DataTemplate>

                        <Frame
                            CornerRadius="15"
                            HasShadow="True"
                            Padding="0">

                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnPasseioClicado"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <VerticalStackLayout Spacing="5">

                                <Image
                                    Source="{Binding ImagemSource}"
                                    HeightRequest="180"
                                    Aspect="AspectFill" />

                                <VerticalStackLayout Padding="10"
                                                     Spacing="5">

                                    <Label
                                        Text="{Binding Nome}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        HorizontalOptions="Center" />

                                    <Label
                                        Text="{Binding QuantidadeCurtidas,
                                               StringFormat='Curtidas: {0}'}"
                                        FontSize="12"
                                        TextColor="Gray" />

                                </VerticalStackLayout>

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>
                </BindableLayout.ItemTemplate>

            </VerticalStackLayout>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>