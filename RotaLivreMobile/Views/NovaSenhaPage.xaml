<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RotaLivreMobile.Views.NovaSenhaPage"
    Title="Nova Senha">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F7FA" Offset="0.0" />
            <GradientStop Color="#FFE9F2F5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout
        Padding="25"
        Spacing="20"
        VerticalOptions="Center">

        <Label
            Text="Definir nova senha"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Entry
            x:Name="novaSenhaEntry"
            Placeholder="Nova senha"
            IsPassword="True"/>

        <Entry
            x:Name="confirmarSenhaEntry"
            Placeholder="Confirmar senha"
            IsPassword="True"/>

        <Button
            Text="Alterar senha"
            Clicked="OnAlterarSenhaClicked"/>

    </VerticalStackLayout>

</ContentPage>