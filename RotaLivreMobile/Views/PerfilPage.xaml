<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RotaLivreMobile.Views.PerfilPage"
             Title="Perfil">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F7FA" Offset="0.0" />
            <GradientStop Color="#FFE9F2F5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

        <Frame Grid.Row="0"
               Padding="0"
               CornerRadius="100"
               HeightRequest="150"
               WidthRequest="150"
               IsClippedToBounds="True"
               HorizontalOptions="Center"
               Margin="0,0,0,20">

            <Image Source="{Binding FotoExibicao}"
               Aspect="AspectFill"/>
        </Frame>
        
        <Label Grid.Row="1"
               Text="{Binding Nome}"
               FontSize="24"
               HorizontalOptions="Center" Margin ="0, 0, 0, 30"/>

        <Label Grid.Row="2" Text="Informações" HorizontalOptions="Center"
               FontAttributes="Bold" FontSize="18"/>

        <VerticalStackLayout Grid.Row="3" Spacing="10">

            <Label Text="{Binding Email}" />
            <Label Text="{Binding DataNasc}" Margin ="0, 0, 0, 50"/>

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="4" Spacing="10">

            <Button Text="Editar Perfil"
                    Clicked="OnEditarClicked" />

            <Button Text="Excluir Conta"
                    BackgroundColor="Red"
                    TextColor="White"
                    Command="{Binding DeletarCommand}" />

            <Button Text="Sair da Conta"
                    Command="{Binding LogoutCommand}" />

        </VerticalStackLayout>

    </Grid>

</ContentPage>