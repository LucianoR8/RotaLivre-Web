<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="RotaLivreMobile.Views.RecuperarSenhaPage"
    Title="Recuperar Senha">
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFF5F7FA" Offset="0.0" />
            <GradientStop Color="#FFE9F2F5" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <VerticalStackLayout
        Padding="25"
        Spacing="20"
        VerticalOptions="Center">

        <Label
            Text="Recuperação de senha"
            FontSize="26"
            FontAttributes="Bold"
            HorizontalOptions="Center"/>

        <Label
            Text="Digite o e-mail da conta"
            FontSize="16"/>

        <Entry
            x:Name="emailEntry"
            Placeholder="E-mail"
            Keyboard="Email"/>

        <Button
            Text="Continuar"
            Clicked="OnContinuarClicked"/>

    </VerticalStackLayout>

</ContentPage>